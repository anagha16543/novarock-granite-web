{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/admin/(.*)",
      "dest": "/admin/$1.php"
    },
    {
      "src": "/(index|about|contact|products|gallery|calculator|licenses|product-view)",
      "dest": "/$1.php"
    }
  ]
}
